// School of Discipleship — Database Schema (Phase 2)
// Normalized relational design. No business logic / API code here —
// this file only defines structure and relationships.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

/// System-wide user roles. Students are NOT a role — they never log in
/// and are modeled as their own entity (Student), not a User.
enum Role {
  SUPER_ADMIN
  MDC_FACILITATOR
  CC_FACILITATOR
}

/// Which program/track a Batch, Class, or Facilitator assignment belongs to.
/// Modeled as an enum (not a table) because it's a fixed, small set that
/// drives access control (facilitators are scoped to one program).
enum Program {
  MDC
  CC
}

/// Attendance status per student per session.
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

/// Student's sex, as recorded on the roster.
enum Sex {
  MALE
  FEMALE
}

/// Age-group classification for a student, used for filtering/reporting.
enum StudentCategory {
  YOUTH
  ADULT
  SENIOR
}

/// Progress state of a Week within a Batch's weekly cycle.
enum WeekStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

/// Broad category an audit log entry belongs to, for filtering in the UI.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  UNLOCK
  LOGIN
  LOGOUT
  GRADE_OVERRIDE
  DEACTIVATE
  REACTIVATE
  RESET_PASSWORD
  ARCHIVE
  UNARCHIVE
  IMPORT
}

// ─────────────────────────────────────────────────────────
// USERS & ROLES
// ─────────────────────────────────────────────────────────

/// A facilitator or Super Admin account. Maps 1:1 to a Supabase Auth user
/// via `authId` (the Supabase `auth.users.id` UUID) — Prisma does not manage
/// authentication itself, only application-level profile/role data.
model User {
  id        String   @id @default(uuid())
  authId    String   @unique // Supabase Auth user id (source of truth for login)
  email     String   @unique
  fullName  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A facilitator (MDC or CC) can be assigned to run several classes over time.
  facilitatedClasses Class[]         @relation("ClassFacilitator")
  auditLogs          AuditLog[]      @relation("AuditActor")
  unlockedRecords    UnlockLog[]     @relation("UnlockActor")
  uploadedFiles      File[]          @relation("FileUploader")
  demeritsIssued     Demerit[]       @relation("DemeritIssuer")
  gradeOverrides     ActivityScore[] @relation("ScoreOverriddenBy")
  weeksCompleted     Week[]          @relation("WeekCompletedBy")
  attendancesLocked  Attendance[]    @relation("AttendanceLockedBy")
  notifications      Notification[]
  announcements      Announcement[]

  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────
// ACADEMIC STRUCTURE: Batch → Class → Group → Student
// ─────────────────────────────────────────────────────────

/// A cohort/term, e.g. "MDC Batch 12" or "CC Batch 3 - 2026". Batches scope
/// classes to a specific run of the program so history isn't overwritten
/// year to year.
model Batch {
  id        String    @id @default(uuid())
  name      String
  program   Program
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  classes Class[]
  weeks   Week[]

  @@index([program])
  @@map("batches")
}

/// A single week within a Batch's weekly cycle (e.g. "Week 1"). Deliberately
/// a lightweight, self-contained checklist for Phase 7 — it does NOT link to
/// Attendance/Activity/PAActivity from Phase 2; each item here is just a
/// simple completion flag/score. Wiring Week to the real grading tables is
/// a later-phase decision once that workflow is designed.
model Week {
  id String @id @default(uuid())

  batchId    String
  weekNumber Int
  label      String? // optional custom title, e.g. "Foundations Week"

  attendanceDone  Boolean @default(false)
  quizDone        Boolean @default(false)
  assignmentDone  Boolean @default(false)
  recitationDone  Boolean @default(false)
  performanceDone Boolean @default(false)
  paDone          Boolean @default(false)
  groupChipsDone  Boolean @default(false)

  notes  String?
  status WeekStatus @default(NOT_STARTED)

  /// Locked once status becomes COMPLETED — edits blocked until a Super
  /// Admin unlocks it (see UnlockLog, same pattern as Attendance/Activity).
  isLocked Boolean @default(false)

  completedById String?
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch       Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  completedBy User? @relation("WeekCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([batchId, weekNumber]) // one Week record per number per batch
  @@index([batchId])
  @@map("weeks")
}

/// A single class/section within a Batch, run by one facilitator.
/// This is the primary unit facilitators interact with day to day.
model Class {
  id            String   @id @default(uuid())
  name          String
  batchId       String
  facilitatorId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  batch       Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facilitator User  @relation("ClassFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)

  groups          Group[]
  students        Student[]
  attendances     Attendance[]
  gradeCategories GradeCategory[]
  paActivities    PAActivity[]
  activities      Activity[]

  @@index([batchId])
  @@index([facilitatorId])
  @@map("classes")
}

/// A small group within a Class (used for group-based activities and
/// GroupChip tracking). A student belongs to at most one group per class.
model Group {
  id        String   @id @default(uuid())
  name      String
  classId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class      Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  students   Student[]
  groupChips GroupChip[]
  paScores   PAScore[]

  @@index([classId])
  @@map("groups")
}

/// Students never log in — this is pure profile/roster data scoped to a
/// single Class (re-enrollment in a new Batch/Class creates a new record,
/// keeping each term's data independent and auditable).
model Student {
  id         String          @id @default(uuid())
  fullName   String
  email      String?
  phone      String?
  sex        Sex
  category   StudentCategory
  isArchived Boolean         @default(false)
  classId    String
  groupId    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  class Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  attendanceRecords AttendanceRecord[]
  activityScores    ActivityScore[]
  demerits          Demerit[]

  @@index([classId])
  @@index([groupId])
  @@map("students")
}

// ─────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────

/// One attendance-taking session for a Class (e.g. a specific date/week).
/// Kept separate from AttendanceRecord so a session's metadata (date,
/// topic) isn't duplicated per student.
model Attendance {
  id          String   @id @default(uuid())
  classId     String
  sessionDate DateTime
  topic       String?
  isLocked    Boolean  @default(false) // locked sessions require Super Admin unlock to edit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lockedById String?
  lockedAt   DateTime?

  class    Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  lockedBy User?              @relation("AttendanceLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  records  AttendanceRecord[]

  @@index([classId])
  @@index([sessionDate])
  @@map("attendances")
}

/// A single student's attendance status for one Attendance session.
/// Normalized out of Attendance so each student's status, not just the
/// session, can be queried/updated independently.
model AttendanceRecord {
  id           String           @id @default(uuid())
  attendanceId String
  studentId    String
  status       AttendanceStatus
  remarks      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([attendanceId, studentId]) // one status per student per session
  @@index([studentId])
  @@map("attendance_records")
}

// ─────────────────────────────────────────────────────────
// GRADING: GradeCategory → Activity → ActivityScore
// ─────────────────────────────────────────────────────────

/// A weighted grading category within a Class (e.g. "Quizzes", "Participation").
/// Weights are configured per class, referencing global defaults in Settings.
model GradeCategory {
  id        String   @id @default(uuid())
  name      String
  weight    Decimal  @db.Decimal(5, 2) // percentage weight, e.g. 30.00
  classId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class      Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([classId])
  @@map("grade_categories")
}

enum ActivityType {
  QUIZ
  ASSIGNMENT
  PERFORMANCE
  RECITATION
}

/// A single gradable item within a GradeCategory (e.g. "Quiz 1").
model Activity {
  id              String       @id @default(uuid())
  title           String
  type            ActivityType
  maxScore        Decimal      @db.Decimal(6, 2)
  classId         String
  gradeCategoryId String?
  isLocked        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  class         Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  gradeCategory GradeCategory?  @relation(fields: [gradeCategoryId], references: [id], onDelete: SetNull)
  scores        ActivityScore[]

  @@index([classId])
  @@index([gradeCategoryId])
  @@map("activities")
}

/// A single student's score on a single Activity. The optional
/// `overriddenById` records which Super Admin manually corrected a score
/// after the record was locked, satisfying the audit requirement.
model ActivityScore {
  id             String   @id @default(uuid())
  activityId     String
  studentId      String
  score          Decimal  @db.Decimal(6, 2)
  overriddenById String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  activity     Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  overriddenBy User?    @relation("ScoreOverriddenBy", fields: [overriddenById], references: [id], onDelete: SetNull)

  @@unique([activityId, studentId]) // one score per student per activity
  @@index([studentId])
  @@map("activity_scores")
}

// ─────────────────────────────────────────────────────────
// PA (PARTICIPATION/PEER ACTIVITY) GRADING
// ─────────────────────────────────────────────────────────

/// A separate gradable-item type from Activity, representing Participation
/// Assessment style activities. Kept distinct from Activity/GradeCategory
/// since PA scoring has its own rubric shape, not weighted-category based.
model PAActivity {
  id          String   @id @default(uuid())
  classId     String
  sessionDate DateTime
  topic       String?
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class  Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  scores PAScore[]

  @@index([classId])
  @@map("pa_activities")
}

/// A single Group's rubric-based Physical Arrangement score for one
/// PAActivity session. Each criterion is entered 0-100; totalScore is the
/// weighted sum using program-specific weights (MDC vs CC differ — see
/// PA_RUBRIC_WEIGHTS in pa.service.ts), computed and stored server-side.
model PAScore {
  id             String  @id @default(uuid())
  paActivityId   String
  groupId        String
  cleanliness    Decimal @db.Decimal(5, 2)
  creativity     Decimal @db.Decimal(5, 2)
  execution      Decimal @db.Decimal(5, 2)
  teamwork       Decimal @db.Decimal(5, 2)
  timeManagement Decimal @db.Decimal(5, 2)
  totalScore     Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paActivity PAActivity @relation(fields: [paActivityId], references: [id], onDelete: Cascade)
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([paActivityId, groupId])
  @@index([groupId])
  @@map("pa_scores")
}

// ─────────────────────────────────────────────────────────
// GROUP CHIPS & DEMERITS
// ─────────────────────────────────────────────────────────

/// A point/token awarded or deducted to a Group (e.g. gamified group
/// participation tracking). Kept as an append-only log (not a running
/// total column) so history and reasons are always auditable.
model GroupChip {
  id        String   @id @default(uuid())
  groupId   String
  amount    Int // positive = awarded, negative = deducted
  reason    String?
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_chips")
}

/// A demerit issued to an individual Student by a facilitator.
model Demerit {
  id         String   @id @default(uuid())
  studentId  String
  issuedById String
  reason     String
  points     Int      @default(1)
  createdAt  DateTime @default(now())

  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy User    @relation("DemeritIssuer", fields: [issuedById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@map("demerits")
}

// ─────────────────────────────────────────────────────────
// FILES
// ─────────────────────────────────────────────────────────

/// Metadata for a file stored in Supabase Storage. Only the storage path
/// and metadata live in Postgres — actual bytes live in Supabase Storage.
/// `entityType`/`entityId` form a lightweight polymorphic association so
/// files can attach to a Student, Class, or Activity without a join
/// table per entity type.
model File {
  id           String   @id @default(uuid())
  fileName     String
  storagePath  String // path within the Supabase Storage bucket
  mimeType     String
  sizeBytes    Int
  entityType   String // e.g. "Student", "Class", "Activity"
  entityId     String
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy User @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@map("files")
}

// ─────────────────────────────────────────────────────────
// AUDIT & UNLOCK LOGS
// ─────────────────────────────────────────────────────────

/// Immutable log of every important action in the system, per the
/// project's "every important action must be logged" requirement.
/// `entityType`/`entityId` again form a lightweight polymorphic link so
/// one table covers actions across all other entities.
model AuditLog {
  id         String      @id @default(uuid())
  actorId    String
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json? // arbitrary before/after diff or context, kept flexible on purpose
  createdAt  DateTime    @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Dedicated log for the Super-Admin-only "unlock records" capability
/// (e.g. re-opening a locked Attendance session or Activity for editing).
/// Kept separate from AuditLog because unlocks carry an explicit reason,
/// which generic audit entries don't structurally require.
model UnlockLog {
  id         String   @id @default(uuid())
  actorId    String
  entityType String // e.g. "Attendance", "Activity", "PAActivity"
  entityId   String
  reason     String
  createdAt  DateTime @default(now())

  actor User @relation("UnlockActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@map("unlock_logs")
}

// ─────────────────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────────────────

enum NotificationType {
  UNLOCK
  ANNOUNCEMENT
}

/// Per-user notification (system-generated: unlocks, drop warnings, etc).
model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

/// A dashboard announcement posted by a Facilitator or Super Admin.
model Announcement {
  id        String   @id @default(uuid())
  authorId  String
  title     String
  body      String
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

/// System-wide key/value configuration managed by Super Admin (e.g. default
/// grade category weights, demerit point thresholds). A single flexible
/// table rather than one column per setting, so new settings don't require
/// migrations.
model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}
