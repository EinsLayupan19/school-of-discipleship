NODE_ENV=development
PORT=4000

# Get from Supabase "Connect" panel > ORM > Prisma
# Pooled connection (used by the app at runtime)
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct/session connection (used only when running migrations)
DIRECT_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Credentials for the seeded Super Admin account (npx prisma db seed)
SEED_SUPER_ADMIN_EMAIL=admin@schoolofdiscipleship.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!

# Get from Supabase Project Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173
